# ========================================
# AMBIENTE
# ========================================
# Modo: 'development' ou 'production'
NODE_ENV=development

# ========================================
# SERVIDOR FRONTEND
# ========================================
# Porta do servidor frontend
PORT=3000

# ========================================
# BACKEND API
# ========================================
# URL do backend (API) - obrigatório em produção
# O frontend faz proxy de /api/* para esta URL (mesma origem para o browser)
BACKEND_API_URL=http://127.0.0.1:8000

# Em produção, use a URL interna do backend (Docker network ou localhost)
# Exemplos:
# BACKEND_API_URL=http://backend:8000  (Docker Compose)
# BACKEND_API_URL=https://api.seudominio.com.br  (Produção com domínio)
